{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "knkode",
	"version": "2.0.3",
	"identifier": "com.knkode.app",
	"build": {
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build",
		"devUrl": "http://localhost:5179",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "knkode",
				"width": 1200,
				"height": 800,
				"minWidth": 600,
				"minHeight": 400,
				"decorations": true,
				"transparent": true,
				"visible": false,
				"shadow": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"trafficLightPosition": { "x": 17, "y": 24 }
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0MDNBODczNTlBMUE1NTcKUldSWHBhRlpjNmdEbEcvSk1GQkxZQkh6VmpGOWZqbWhpdVZZdjU3ZENhdmQ4eUhST0pEZmpIOG8K",
			"endpoints": [
				"https://github.com/knkenko/knkode/releases/latest/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
